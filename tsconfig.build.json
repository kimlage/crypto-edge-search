{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "incremental": false,
    "tsBuildInfoFile": null,
    "plugins": []
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "output",
    "docs",
    "scripts",
    "test",
    "next-env.d.ts",
    ".next",
    "**/*.test.ts",
    "src/cli/**"
  ]
}

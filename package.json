{
  "name": "crypto-edge-search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "crypto-edge": "src/cli/crypto-edge.ts"
  },
  "scripts": {
    "crypto-edge": "tsx src/cli/crypto-edge.ts",
    "build": "tsc --noEmit",
    "build:lib": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "schema:validate": "tsx scripts/validate-schemas.ts",
    "results:check": "tsx scripts/check-results-consistency.ts",
    "dashboard:build": "tsx scripts/build-dashboard.ts",
    "dashboard:check": "tsx scripts/build-dashboard.ts && git diff --exit-code docs/dashboard.html",
    "refs:check": "tsx scripts/refs-check.ts",
    "test:property": "vitest run test/property",
    "prepublishOnly": "npm run build:lib && npm test"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "onnxruntime-node": "^1.26.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "tsx": "^4.22.3",
    "typescript": "^5.5.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "postcss": "^8.5.14"
  }
}
